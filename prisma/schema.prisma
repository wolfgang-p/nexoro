generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Abgabestellen {
  id              Int       @id @default(autoincrement())
  partnerId       Int?      @default(0) @map("partner_id")
  abholung        String?
  art             String?   @default("Annahmestelle (Partner)")
  ansprechperson  String?
  strasse         String?
  plz             String?
  ort             String?
  land            String?   @default("Österreich")
  von             String?   @default("08:00")
  bis             String?   @default("18:00")
  telefonnummer   String?
  email           String?
  abgabeFirma     String?   @map("abgabe_firma")
  oeffnungszeit   String?
  wegbeschreibung String?
  zusatzId        String?   @map("zusatz_id")
  notInId         String?   @map("not_in_id")
  partnerstufe    String?
  standortArt     String?   @map("standort_art")
  telAnzStandort  String?   @map("tel_anz_standort")
  mailAnzStandort String?   @map("mail_anz_standort")
  createdAt       DateTime? @map("created_at")
  updatedAt       DateTime? @map("updated_at")
  userLastSave    String?   @map("user_last_save")
  aktiv           Int?      @default(1)
  
  partners PartnersAbgabestellen[]
  lat             String?
  lng             String?
  footerTextIndiv String?   @map("footer_text_indiv")
  regionalcode    String?

  @@map("abgabestellen")
}

model Abgabestellen1 {
  id                       Int       @id @default(autoincrement())
